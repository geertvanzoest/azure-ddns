# ns4j — Azure DDNS Client Configuration
# Copy this file to /etc/ns4j/.env and fill in your values.

# ---------------------------------------------------------------------------
# Azure Service Principal (required)
# Create with: az ad sp create-for-rbac --name "ns4j" \
#   --role "DNS Zone Contributor" \
#   --scopes "/subscriptions/<SUB>/resourceGroups/<RG>/providers/Microsoft.Network/dnsZones/<ZONE>"
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Azure DNS Zone (required)
# ---------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_DNS_ZONE=example.com
AZURE_DNS_RECORD=home

# ---------------------------------------------------------------------------
# Optional settings
# ---------------------------------------------------------------------------
# DNS_TTL=300                  # TTL in seconds (default: 300)
# STATE_DIR=/run/ns4j          # State directory, use tmpfs to avoid SD card wear
# CHECK_INTERVAL_MS=300000     # Check interval in ms (default: 5 min, daemon mode only)
# FORCE_INTERVAL_MS=86400000   # Force DNS refresh interval (default: 24h)
# REQUEST_TIMEOUT_MS=10000     # HTTP request timeout (default: 10s)
# DAEMON_MODE=false            # Set to 'true' for long-running daemon instead of oneshot
